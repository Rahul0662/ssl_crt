Centreon HTTPS Setup (RHEL 9.7) - Single File Configuration

1) Install SSL module
dnf install mod_ssl -y

2) Create SSL cert + key (same folder)
mkdir -p /etc/httpd/ssl

# IP case
openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
-keyout /etc/httpd/ssl/centreon.key \
-out /etc/httpd/ssl/centreon.crt \
-subj "/CN=192.168.137.148"

# FQDN case
openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
-keyout /etc/httpd/ssl/centreon.key \
-out /etc/httpd/ssl/centreon.crt \
-subj "/CN=centreon.mycompany.com"

3) Disable old Centreon configs (rename only)
cd /etc/httpd/conf.d
mv 10-centreon.conf 10-centreon.conf.bkp
mv ssl.conf ssl.conf.bkp

4) Create SINGLE config (with variables)
vi /etc/httpd/conf.d/centreon.conf

Paste:

Define SERVER_NAME 192.168.137.148
# or
# Define SERVER_NAME centreon.mycompany.com

ServerName ${SERVER_NAME}

#Listen 80
Listen 443

Define base_uri "/centreon"
Define install_dir "/usr/share/centreon"

<VirtualHost *:80>
    ServerName ${SERVER_NAME}
    RedirectMatch ^/(.*)$ https://${SERVER_NAME}/$1
</VirtualHost>

<VirtualHost *:443>
    ServerName ${SERVER_NAME}

    SSLEngine on
    SSLCertificateFile /etc/httpd/ssl/centreon.crt
    SSLCertificateKeyFile /etc/httpd/ssl/centreon.key

    Header set X-Frame-Options: "sameorigin"
    Header always edit Set-Cookie ^(.*)$ $1;HttpOnly;SameSite=Strict
    ServerSignature Off
    TraceEnable Off

    Alias ${base_uri}/api ${install_dir}
    Alias ${base_uri} ${install_dir}/www/

    <LocationMatch ^\\${base_uri}/?(?!api/latest/|api/beta/|api/v[0-9]+/|api/v[0-9]+\\.[0-9]+/)(.*\\.php(/.*)?)$>
        ProxyPassMatch "fcgi://127.0.0.1:9042${install_dir}/www/$1"
    </LocationMatch>

    <LocationMatch ^\\${base_uri}/?(authentication|api/(latest|beta|v[0-9]+|v[0-9]+\\.[0-9]+))/.*$>
        ProxyPassMatch "fcgi://127.0.0.1:9042${install_dir}/api/index.php/$1"
    </LocationMatch>

    ProxyTimeout 300
    ErrorDocument 404 ${base_uri}/index.html
    Options -Indexes +FollowSymLinks

    <Directory "${install_dir}/www">
        DirectoryIndex index.php
        AllowOverride none
        Require all granted
        FallbackResource ${base_uri}/index.html
    </Directory>

    <Directory "${install_dir}/api">
        AllowOverride none
        Require all granted
    </Directory>
</VirtualHost>

5) Apache restart
systemctl restart httpd

6) Firewall allow 
firewall-cmd --add-service=https --permanent
firewall-cmd --reload

7) Verify 
ss -tulnp | grep 443
curl -k https://localhost/centreon

Access:
https://192.168.137.148/centreon
or
https://centreon.mycompany.com/centreon
